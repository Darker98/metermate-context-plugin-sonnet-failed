{
  "name": "@metermate/server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node ../node_modules/.bin/tsx watch src/index.ts",
    "build": "tsc",
    "test": "jest --forceExit",
    "seed": "node ../node_modules/.bin/tsx src/seed.ts"
  },
  "dependencies": {
    "@maxio-com/advanced-billing-sdk": "9.0.0",
    "slack-apimatic-sdk": "1.0.0",
    "express": "^4.19.2",
    "zod": "^3.23.8",
    "dotenv": "^16.4.5",
    "node-cron": "^3.0.3",
    "uuid": "^10.0.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "@types/cors": "^2.8.17",
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "tsx": "^4.15.7",
    "typescript": "^5.5.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/tests"
    ],
    "testMatch": [
      "**/*.test.ts"
    ]
  }
}
