# Maxio Advanced Billing
MAXIO_API_KEY=your-api-key-here
MAXIO_SITE_SUBDOMAIN=your-test-site
MAXIO_ENVIRONMENT=US
MAXIO_DEFAULT_PRODUCT_FAMILY=metermate

# EBB metric — create in Maxio UI first, then paste the metric ID here
MAXIO_API_CALLS_METRIC_ID=

# Slack (bot-token app)
# Required scopes: chat:write, groups:write, users:read.email, groups:read
SLACK_BOT_TOKEN=xoxb-...
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_DIGEST_CHANNEL=

# Admin (placeholder auth — replace before production)
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# App
PORT=4000
SESSION_TTL_MINUTES=30
DEMO_MODE=true
DIGEST_CRON=0 9 * * 1
